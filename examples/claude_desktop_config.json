{
  "mcpServers": {
    "damask": {
      "command": "conda",
      "args": [
        "run",
        "--no-capture-output",
        "-n",
        "damaskcp",
        "python",
        "-m",
        "damask_mcp.mcp_servers.damask_server"
      ],
      "cwd": "/ABSOLUTE/PATH/TO/DAMASK-MCP",
      "env": {
        "PYTHONPATH": "/ABSOLUTE/PATH/TO/DAMASK-MCP/src"
      }
    }
  }
}
